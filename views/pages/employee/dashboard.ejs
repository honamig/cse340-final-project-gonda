<%- include('../../partials/header') %>

<h2>Employee Dashboard</h2>

<% if (messages.error.length > 0) { %>
  <p class="error"><%= messages.error[0] %></p>
<% } %>
<% if (messages.success.length > 0) { %>
  <p class="success"><%= messages.success[0] %></p>
<% } %>

<h3>Vehicles</h3>
<table class="vehicle-specs">
  <tr><th>Vehicle</th><th>Price</th><th>Status</th><th></th></tr>
  <% vehicles.forEach(function(vehicle) { %>
    <tr>
      <td><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></td>
      <td>$<%= vehicle.price %></td>
      <td><%= vehicle.availabilityStatus %></td>
      <td><a href="/employee/vehicles/<%= vehicle.vehicleId %>/edit">Edit</a></td>
    </tr>
  <% }); %>
</table>

<h3>Reviews</h3>
<table class="vehicle-specs">
  <tr><th>Vehicle</th><th>Reviewer</th><th>Rating</th><th>Comment</th><th></th></tr>
  <% reviews.forEach(function(review) { %>
    <tr>
      <td><%= review.vehicleMake %> <%= review.vehicleModel %></td>
      <td><%= review.reviewerFirstName %></td>
      <td><%= review.rating %>/5</td>
      <td><%= review.comment %></td>
      <td>
        <form action="/employee/reviews/<%= review.reviewId %>/delete" method="POST" style="display:inline;">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
  <% }); %>
</table>

<h3>Service Requests</h3>
<table class="vehicle-specs">
  <tr><th>Customer</th><th>Vehicle</th><th>Service</th><th>Status</th><th></th></tr>
  <% serviceRequests.forEach(function(request) { %>
    <tr>
      <td><%= request.customerFirstName %> <%= request.customerLastName %></td>
      <td>
        <% if (request.vehicleMake) { %>
          <%= request.vehicleYear %> <%= request.vehicleMake %> <%= request.vehicleModel %>
        <% } else { %>
          (N/A)
        <% } %>
      </td>
      <td><%= request.serviceType %></td>
      <td><%= request.status %></td>
      <td><a href="/employee/service-requests/<%= request.requestId %>/edit">Update</a></td>
    </tr>
  <% }); %>
</table>

<h3>Contact Messages</h3>
<table class="vehicle-specs">
  <tr><th>From</th><th>Subject</th><th>Message</th><th>Status</th><th>Reply</th></tr>
  <% contactMessages.forEach(function(msg) { %>
    <tr>
      <td><%= msg.name %> (<%= msg.email %>)</td>
      <td><%= msg.subject %></td>
      <td><%= msg.message %></td>
      <td><%= msg.status %></td>
      <td>
        <form action="/employee/contact-messages/<%= msg.messageId %>/reply" method="POST">
          <textarea name="replyText" rows="2" placeholder="Write a reply..."><%= msg.replyText || "" %></textarea>
          <button type="submit">Send Reply</button>
        </form>
      </td>
    </tr>
  <% }); %>
</table>

<%- include('../../partials/footer') %>