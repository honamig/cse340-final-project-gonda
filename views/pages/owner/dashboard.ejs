<%- include('../../partials/header') %>

<h2>Owner Dashboard</h2>

<% if (messages.error.length > 0) { %>
  <p class="error"><%= messages.error[0] %></p>
<% } %>
<% if (messages.success.length > 0) { %>
  <p class="success"><%= messages.success[0] %></p>
<% } %>

<p><a href="/employee/dashboard">Go to Employee Dashboard</a></p>

<h3>Categories</h3>
<table class="vehicle-specs">
  <tr><th>Name</th><th>Description</th><th></th></tr>
  <% categories.forEach(function(category) { %>
    <tr>
      <td><%= category.name %></td>
      <td><%= category.description %></td>
      <td>
        <form action="/owner/categories/<%= category.categoryId %>/delete" method="POST" style="display:inline;">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
  <% }); %>
</table>
<a href="/owner/categories/add">+ Add Category</a>

<h3>Vehicles</h3>
<table class="vehicle-specs">
  <tr><th>Vehicle</th><th>Price</th><th></th></tr>
  <% vehicles.forEach(function(vehicle) { %>
    <tr>
      <td><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></td>
      <td>$<%= vehicle.price %></td>
      <td>
        <form action="/owner/vehicles/<%= vehicle.vehicleId %>/delete" method="POST" style="display:inline;">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
  <% }); %>
</table>
<a href="/owner/vehicles/add">+ Add Vehicle</a>

<h3>Staff</h3>
<table class="vehicle-specs">
  <tr><th>Name</th><th>Email</th><th>Role</th></tr>
  <% staff.forEach(function(person) { %>
    <tr>
      <td><%= person.firstName %> <%= person.lastName %></td>
      <td><%= person.email %></td>
      <td><%= person.role %></td>
    </tr>
  <% }); %>
</table>

<h4>Add Employee</h4>
<form action="/owner/employees/add" method="POST">
  <label for="firstName">First Name</label>
  <input type="text" id="firstName" name="firstName" required>

  <label for="lastName">Last Name</label>
  <input type="text" id="lastName" name="lastName" required>

  <label for="email">Email</label>
  <input type="email" id="email" name="email" required>

  <label for="password">Password</label>
  <input type="password" id="password" name="password" required minlength="8">

  <button type="submit">Create Employee Account</button>
</form>

<%- include('../../partials/footer') %>