<%- include('../partials/header') %>

<h2>Welcome</h2>
<p>Featured Vehicles</p>

<div class="vehicle-grid">
  <% featuredVehicles.forEach(function(vehicle) { %>
    <div class="vehicle-card">
      <a href="/vehicle/<%= vehicle.vehicleId %>">
        <img src="<%= vehicle.imageUrl || 'https://placehold.co/400x300?text=No+Image' %>" alt="<%= vehicle.make %> <%= vehicle.model %>">
        <h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>
        <p>$<%= vehicle.price %></p>
      </a>
    </div>
  <% }); %>
</div>

<%- include('../partials/footer') %>